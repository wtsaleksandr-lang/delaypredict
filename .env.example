# DelayPredict — copy to .env (file is gitignored)
# Set whichever providers you have keys for. Adapters auto-skip if blank.

# ── Universal aggregator (recommended starting point) ─────────────────────────
# 17TRACK — 100 free trackings/mo, 3200+ carriers (ocean container + AWB)
#   Sign up: https://api.17track.net/  (admin.17track.net/api → Settings → Access Key)
SEVENTEENTRACK_API_KEY=

# ── Carrier-direct (free, authoritative — preferred when shipment uses these) ─
# Maersk Track & Trace Plus — register an app at developer.maersk.com
#   Subscribe to "Track & Trace Plus" product → copy Consumer Key
MAERSK_CONSUMER_KEY=

# Hapag-Lloyd Tracing — register at api-portal.hlag.com (IBM API Connect)
#   Subscribe to "Tracing" product → copy Client ID + Secret
HAPAG_CLIENT_ID=
HAPAG_CLIENT_SECRET=

# CMA CGM — register at apis.cma-cgm.com (approval may take 1-2 days)
#   OAuth2 client_credentials
CMACGM_CLIENT_ID=
CMACGM_CLIENT_SECRET=

# ── LLM route-risk oracle (Phase 3, optional) ────────────────────────────────
# Claude Haiku call per (origin, destination, ISO-week). Cached so you pay ~once
# per route per week. Estimated cost: <$0.01 per call at typical input sizes.
# Without this key, route risk falls back to the scraper / manual input.
#   Sign up: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Air freight (flight-level tracking) ──────────────────────────────────────
# OpenSky Network — free; OAuth2 client credentials
# (Basic auth was deprecated March 2026.)
#   Sign up:  https://opensky-network.org  →  Account → Create API client
#   Quota:    4000 credits/day on the default role
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# ── App ───────────────────────────────────────────────────────────────────────
PORT=5000
# Optional: only required if you switch storage from JsonFileStorage to Postgres
# DATABASE_URL=postgres://user:pass@localhost:5432/delaypredict
